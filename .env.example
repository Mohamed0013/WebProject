# ============================================================
#  Maroc Speak — Environment Variables
#  Copy this file: cp .env.example .env
#  Then fill in the values marked with CHANGE_ME
# ============================================================


# ─────────────────────────────────────────────────────────────
#  APP
# ─────────────────────────────────────────────────────────────
APP_NAME="Maroc Speak"
APP_ENV=local                        # local | production
APP_KEY=                             # Auto-generated by: make key
APP_DEBUG=true                       # Set false in production
APP_URL=http://localhost
APP_PORT=80

FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost/api


# ─────────────────────────────────────────────────────────────
#  DATABASE — MySQL
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=maroc_speak
DB_USERNAME=darija_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD


# ─────────────────────────────────────────────────────────────
#  CACHE & SESSIONS — Redis
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120                 # minutes
QUEUE_CONNECTION=redis


# ─────────────────────────────────────────────────────────────
#  FILE STORAGE — MinIO (S3-compatible)
#  Used for professor video/audio uploads
# ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3

MINIO_USER=CHANGE_ME_MINIO_USER
MINIO_PASSWORD=CHANGE_ME_MINIO_PASSWORD      # min 12 characters

AWS_ACCESS_KEY_ID="${MINIO_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_PASSWORD}"
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=maroc-speak
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true     # Required for MinIO

MINIO_CONSOLE_PORT=9001


# ─────────────────────────────────────────────────────────────
#  AUTHENTICATION — Laravel Sanctum
# ─────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1
SESSION_DOMAIN=localhost

# Token expiration (in minutes — 720 = 12 hours)
SANCTUM_TOKEN_EXPIRATION=720


# ─────────────────────────────────────────────────────────────
#  MAIL (for password reset, welcome emails)
# ─────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit                    # Use mailpit service for local dev
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@maroc-speak.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Production (e.g. Brevo / Mailgun / SES) ──────────────────
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=CHANGE_ME
# MAIL_PASSWORD=CHANGE_ME
# MAIL_ENCRYPTION=tls


# ─────────────────────────────────────────────────────────────
#  LOGGING
# ─────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                      # debug | info | warning | error


# ─────────────────────────────────────────────────────────────
#  SPEECH / QUIZ ENGINE
#  Used for student audio-repeat quiz validation
# ─────────────────────────────────────────────────────────────

# Tolerance for speech-to-text answer matching (0.0 to 1.0)
# 0.7 = 70% similarity required to pass
QUIZ_SPEECH_MATCH_THRESHOLD=0.7

# Max video size professors can upload (in MB)
UPLOAD_MAX_VIDEO_SIZE_MB=500

# Max audio clip size for quiz sentences (in MB)
UPLOAD_MAX_AUDIO_SIZE_MB=20


# ─────────────────────────────────────────────────────────────
#  ADMIN DEFAULTS (used by seeder to create first admin)
# ─────────────────────────────────────────────────────────────
ADMIN_NAME="Super Admin"
ADMIN_EMAIL=admin@maroc-speak.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD      # Change immediately after first login
